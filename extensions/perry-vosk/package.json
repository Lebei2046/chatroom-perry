{
  "name": "perry-vosk",
  "version": "0.1.0",
  "description": "Vosk speech recognition for Perry",
  "main": "src/index.ts",
  "perry": {
    "nativeLibrary": {
      "abiVersion": "0.5",
      "functions": [
        { "name": "vosk_is_available", "params": [], "returns": "f64" },
        { "name": "vosk_start", "params": ["callback"], "returns": "i64" },
        { "name": "vosk_stop", "params": ["i64"], "returns": "void" },
        { "name": "vosk_convert_file", "params": ["string", "callback"], "returns": "void" },
        { "name": "vosk_process_samples", "params": ["f64", "f64"], "returns": "void" }
      ],
      "targets": {
        "linux": {
          "crate": "crate-linux",
          "lib": "libperry_vosk.a",
          "libs": ["vosk"]
        },
        "macos": {
          "lib": "libperry_vosk.a"
        }
      }
    }
  }
}