{
  "name": "perry-vosk",
  "version": "0.1.0",
  "description": "Vosk speech recognition for Perry",
  "main": "src/index.ts",
  "perry": {
    "nativeLibrary": {
      "abiVersion": "0.5",
      "functions": [
        { "name": "voskIsAvailable", "params": [], "returns": "f64" },
        { "name": "voskStart", "params": ["callback"], "returns": "i64" },
        { "name": "voskStop", "params": ["i64"], "returns": "void" },
        { "name": "voskConvertFile", "params": ["string", "callback"], "returns": "void" },
        { "name": "voskProcessSamples", "params": ["pointer", "usize"], "returns": "void" }
      ],
      "targets": {
        "linux": {
          "crate": "crate-linux",
          "lib": "libperry_vosk.a",
          "libs": ["vosk"],
          "libDirs": ["/usr/local/lib"]
        },
        "macos": {
          "lib": "libperry_vosk.a"
        }
      }
    }
  }
}